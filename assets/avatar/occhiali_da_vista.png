<svg width="300" height="400" xmlns="http://www.w3.org/2000/svg">
  <!-- Occhiali da vista neri -->
  <ellipse cx="130" cy="95" rx="25" ry="20" fill="none" stroke="#2c2c2c" stroke-width="4"/>
  <ellipse cx="170" cy="95" rx="25" ry="20" fill="none" stroke="#2c2c2c" stroke-width="4"/>
  <!-- Lenti -->
  <ellipse cx="130" cy="95" rx="22" ry="17" fill="#e6f3ff" opacity="0.3"/>
  <ellipse cx="170" cy="95" rx="22" ry="17" fill="#e6f3ff" opacity="0.3"/>
  <!-- Ponte naso -->
  <rect x="145" y="92" width="10" height="6" fill="#2c2c2c"/>
  <rect x="147" y="94" width="6" height="2" fill="#1a1a1a"/>
  <!-- Aste -->
  <rect x="105" y="93" width="25" height="4" fill="#2c2c2c"/>
  <rect x="170" y="93" width="25" height="4" fill="#2c2c2c"/>
  <!-- Riflessi sulle lenti -->
  <ellipse cx="125" cy="90" rx="8" ry="6" fill="white" opacity="0.6"/>
  <ellipse cx="165" cy="90" rx="8" ry="6" fill="white" opacity="0.6"/>
  <ellipse cx="135" cy="100" rx="4" ry="3" fill="white" opacity="0.4"/>
  <ellipse cx="175" cy="100" rx="4" ry="3" fill="white" opacity="0.4"/>
</svg>
