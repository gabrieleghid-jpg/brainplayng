<svg width="300" height="400" xmlns="http://www.w3.org/2000/svg">
  <!-- Monocle elegante -->
  <circle cx="170" cy="95" r="22" fill="none" stroke="#2c2c2c" stroke-width="3"/>
  <!-- Lente -->
  <circle cx="170" cy="95" r="19" fill="#e6f3ff" opacity="0.3"/>
  <!-- Catena -->
  <path d="M 150 85 Q 160 75 170 85" fill="none" stroke="#2c2c2c" stroke-width="2"/>
  <path d="M 148 83 Q 158 73 168 83" fill="none" stroke="#2c2c2c" stroke-width="1"/>
  <!-- Dettagli catena -->
  <circle cx="155" cy="78" r="1" fill="#2c2c2c"/>
  <circle cx="160" cy="75" r="1" fill="#2c2c2c"/>
  <circle cx="165" cy="78" r="1" fill="#2c2c2c"/>
  <!-- Riflesso sulla lente -->
  <ellipse cx="165" cy="90" rx="8" ry="6" fill="white" opacity="0.6"/>
  <ellipse cx="175" cy="100" rx="4" ry="3" fill="white" opacity="0.4"/>
  <!-- Cornice decorativa -->
  <circle cx="170" cy="95" r="24" fill="none" stroke="#8b4513" stroke-width="1"/>
  <circle cx="170" cy="95" r="26" fill="none" stroke="#8b4513" stroke-width="1"/>
  <!-- Piccolo dettaglio dorato -->
  <circle cx="150" cy="85" r="3" fill="#ffd700"/>
  <circle cx="150" cy="85" r="2" fill="#ffed4e"/>
</svg>
