  <rect x="90" y="145" width="20" height="80" fill="#6a0dad"/>
  <rect x="190" y="145" width="20" height="80" fill="#6a0dad"/>
  <rect x="120" y="235" width="60" height="120" fill="#6a0dad"/>
  <rect x="110" y="340" width="18" height="95" fill="#6a0dad"/>
  <rect x="172" y="340" width="18" height="95" fill="#6a0dad"/>
  <!-- Dettagli metallici -->
  <rect x="115" y="140" width="70" height="5" fill="#c0c0c0"/>
  <rect x="125" y="240" width="50" height="5" fill="#c0c0c0"/>
