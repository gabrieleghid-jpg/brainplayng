<svg width="300" height="400" xmlns="http://www.w3.org/2000/svg">
  <!-- Cuffie natalizie rosse con ponpon -->
  <ellipse cx="150" cy="80" rx="50" ry="30" fill="#dc143c"/>
  <ellipse cx="150" cy="75" rx="50" ry="25" fill="#ff0000"/>
  <!-- Bordo bianco -->
  <rect x="100" y="95" width="100" height="8" fill="white"/>
  <rect x="95" y="98" width="110" height="5" fill="#f0f0f0"/>
  <!-- Ponpon bianco -->
  <circle cx="150" cy="65" r="12" fill="white"/>
  <circle cx="150" cy="65" r="8" fill="#f5f5f5"/>
  <!-- Dettagli texture -->
  <circle cx="130" cy="75" r="2" fill="#8b0000"/>
  <circle cx="150" cy="70" r="2" fill="#8b0000"/>
  <circle cx="170" cy="75" r="2" fill="#8b0000"/>
  <circle cx="140" cy="85" r="2" fill="#8b0000"/>
  <circle cx="160" cy="85" r="2" fill="#8b0000"/>
  <!-- Piccoli fiocchi di neve -->
  <circle cx="125" cy="70" r="1" fill="white"/>
  <circle cx="175" cy="70" r="1" fill="white"/>
  <circle cx="135" cy="80" r="1" fill="white"/>
  <circle cx="165" cy="80" r="1" fill="white"/>
</svg>
